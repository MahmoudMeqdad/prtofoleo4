{
  "name": "iplay",
  "private": true,
  "version": "0.1.0",
  "description": "IPLAY — An integrated children's toys commerce platform",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@iplay/web",
    "dev:api": "turbo dev --filter=@iplay/api",
    "build": "turbo build",
    "build:web": "turbo build --filter=@iplay/web",
    "build:api": "turbo build --filter=@iplay/api",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.2",
    "typescript": "^5.8.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
