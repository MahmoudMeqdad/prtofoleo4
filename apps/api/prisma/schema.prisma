generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  MARKETER
  WHOLESALE_TRADER
  ORDER_EMPLOYEE
  SALES_MANAGER
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  phone        String?       @unique
  passwordHash String
  role         UserRole
  status       AccountStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  refreshTokens         RefreshToken[]
  marketerProfile       MarketerProfile?
  wholesaleTraderProfile WholesaleTraderProfile?
  statusHistoryAsTarget AccountStatusHistory[] @relation("StatusHistoryTarget")
  statusHistoryAsReviewer AccountStatusHistory[] @relation("StatusHistoryReviewer")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MarketerProfile {
  userId              String @id
  whatsappNumber      String
  city                String
  businessOrPageName  String
  facebookPage        String?
  instagramPage       String?
  marketingMethod     String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WholesaleTraderProfile {
  userId              String  @id
  businessName        String
  businessType        String
  city                String
  address             String
  expectedOrderVolume String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AccountStatusHistory {
  id             String        @id @default(cuid())
  userId         String
  reviewerId     String
  previousStatus AccountStatus
  newStatus      AccountStatus
  note           String?
  createdAt      DateTime      @default(now())

  user     User @relation("StatusHistoryTarget", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User @relation("StatusHistoryReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([reviewerId])
  @@index([createdAt])
}
